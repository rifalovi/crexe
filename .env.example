# ─── CREXE — Variables d'environnement requises ──────────────────────────────
# Copiez ce fichier en .env.local et remplissez vos valeurs.
# ⚠️  Ne commitez JAMAIS .env.local dans git (.gitignore déjà configuré).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_key

# ── IA — Anthropic Claude (chatbot + parseur documents) ──────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE

# ── IA — OpenAI (chatbot legacy, PDF vision) ──────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-VOTRE_CLE

# ── Email — Resend (formulaire de contact) ────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_VOTRE_CLE

# ── Anti-bot — Cloudflare Turnstile (formulaire de contact) ──────────────────
# dash.cloudflare.com → Turnstile → Votre site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4VOTRE_SITE_KEY
TURNSTILE_SECRET_KEY=0x4VOTRE_SECRET_KEY

# ── Embeddings — Voyage AI (optionnel, améliore la qualité du chatbot RAG) ───
# voyageai.com → API Keys
VOYAGE_API_KEY=pa-VOTRE_CLE
